{
  "name": "opencode-rules-md",
  "version": "0.6.5",
  "description": "OpenCode plugin that discovers and injects markdown rules into system prompts",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "type": "module",
  "bin": {
    "opencode-rules-md": "./dist/cli.mjs"
  },
  "oc-plugin": [
    "server",
    "tui"
  ],
  "scripts": {
    "build": "tsc && bun run build:cli",
    "build:cli": "bun build src/cli/main.ts --outfile dist/cli.mjs --target node",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src tui",
    "format": "prettier --write 'src/**/*.ts' 'tui/**/*.tsx' 'tui/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tui/**/*.tsx' 'tui/**/*.ts'",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run clean && bun run build"
  },
  "keywords": [
    "opencode",
    "plugin",
    "rules",
    "system-prompt",
    "typescript"
  ],
  "author": "MetalbolicX",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MetalbolicX/opencode-rules-md.git"
  },
  "bugs": {
    "url": "https://github.com/MetalbolicX/opencode-rules-md/issues"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*",
    "!dist/**/test-fixtures.*",
    "!dist/**/api-surface.typecheck.*",
    "src/",
    "!src/**/*.test.ts",
    "!src/**/*.spec.ts",
    "!src/test-fixtures.ts",
    "!src/api-surface.typecheck.ts",
    "tui/",
    "!tui/**/*.test.ts",
    "!tui/**/*.test.tsx",
    "!tui/**/*.spec.ts",
    "!tui/**/*.spec.tsx",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./tui": {
      "types": "./dist/tui/index.d.ts",
      "import": "./tui/index.tsx"
    },
    "./cli": {
      "types": "./dist/cli/main.d.ts",
      "import": "./dist/cli.mjs"
    }
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.3.9",
    "@opencode-ai/sdk": "^1.3.9",
    "@opentui/core": "^0.4.3",
    "@opentui/solid": "^0.4.3",
    "solid-js": "1.9.14"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.3.9",
    "@opencode-ai/sdk": "^1.3.9",
    "@opentui/core": "^0.4.3",
    "@opentui/solid": "^0.4.3",
    "@types/minimatch": "^5.1.2",
    "@types/node": "^20.19.30",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "eslint": "^10.6.0",
    "prettier": "^3.8.1",
    "solid-js": "1.9.14",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "minimatch": "^9.0.5",
    "yaml": "^2.8.2"
  }
}
